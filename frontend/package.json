    "@vitejs/plugin-react": "^4.3.4",
    "autoprefixer": "^10.4.19",
    "postcss": "^8.4.48",
    "tailwindcss": "^3.4.4",
    "typescript": "^5.5.4",
    "vite": "^6.4.1"
  }
