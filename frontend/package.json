{
  "name": "dobFrontend",
  "version": "0.1.0",
  "private": true,
  "dependencies": {
    "@capacitor/android": "^6.2.1",
    "@capacitor/cli": "^6.2.1",
    "@capacitor/core": "^6.2.1",
    "@capacitor/ios": "^6.2.1",
    "@stomp/stompjs": "^7.2.0",
    "axios": "^1.7.2",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "@tanstack/react-query": "^5.74.4",
    "sockjs-client": "^1.6.1"
  },
  "scripts": {
    "start": "vite",
    "build": "tsc --noEmit && vite build",
