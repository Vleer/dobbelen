# Web development (CRA)
# - Uses localhost backend by default.
REACT_APP_BACKEND_URL=http://localhost:8080

# Web production (recommended)
# - Leave empty to use same-origin and proxy /api + /ws at the web server.
# REACT_APP_BACKEND_URL=

# Mobile (Capacitor) builds (required)
# - Must be reachable from the phone (NOT localhost).
# - Prefer https:// and wss:// via the same base.
# REACT_APP_BACKEND_URL=https://your-backend.example.com

# If you absolutely must test cleartext HTTP on-device (not recommended):
# REACT_APP_ALLOW_INSECURE_HTTP=true

# Optional: enable ingress base path routing (Kubernetes)
# REACT_APP_USE_INGRESS=true
