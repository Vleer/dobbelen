# Copy this file to .env and fill in your values.
# Do not commit .env to version control.

# Host path to your cloudflared config directory (e.g. ~/.cloudflared)
CLOUDFLARED_CONFIG_PATH=/path/to/your/.cloudflared

# Your Cloudflare Tunnel ID (from Zero Trust dashboard or `cloudflared tunnel list`)
CLOUDFLARED_TUNNEL_ID=your-tunnel-id-here
